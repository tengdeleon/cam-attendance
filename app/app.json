{
  "expo": {
    "name": "CAM",
    "slug": "center-attendance-monitoring",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tengdeleon.cam"
    },
    "android": {
      "package": "com.tengdeleon.cam",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "CAM uses the camera to capture a verification selfie at attendance check-in/out."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "337c755a-5d4e-4815-98b8-f23b6c26557c"
      }
    },
    "owner": "tengdeleons-team",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/337c755a-5d4e-4815-98b8-f23b6c26557c"
    }
  }
}
