# FastAPI <-> Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service-role-key   # server-only, never ship to client
SUPABASE_JWT_SECRET=your-jwt-secret          # to verify client access tokens
SELFIE_BUCKET=selfies
RETENTION_DAYS=90
ALLOWED_ORIGINS=http://localhost:8081,exp://127.0.0.1:19000
